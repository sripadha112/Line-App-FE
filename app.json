{
  "expo": {
    "name": "kedulz",
    "slug": "kedulz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ios/iTunesArtwork@3x.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/ios/iTunesArtwork@2x.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.santhu112.lineapp",
      "icon": "./assets/ios/iTunesArtwork@2x.png",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android/ic_launcher-web.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.santhu_112.lineapp",
      "googleServicesFile": "./google-services.json",
      "icon": "./assets/android/playstore-icon.png",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon-96x96.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/android/mipmap-hdpi/ic_launcher.png",
          "color": "#2196F3",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "notification": {
      "icon": "./assets/android/mipmap-hdpi/ic_launcher.png",
      "color": "#2196F3",
      "androidMode": "default",
      "androidCollapsedTitle": "kedulz - Appointment Reminder",
      "iosDisplayInForeground": true
    },
    "extra": {
      "eas": {
        "projectId": "8efebfa6-33b2-4cb2-a05b-3ff0d87b14a9"
      }
    }
  }
}
